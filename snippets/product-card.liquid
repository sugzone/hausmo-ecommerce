{% doc %}
  Renders a product card with image and title.

  @param {product} product - The product to render
  @param {string} [image_size] - Image size in px (default: 400)
{% enddoc %}

{% assign img_size = image_size | default: 400 %}

<a href="{{ product.url }}" class="product-card">
  {% if product.featured_image %}
    {{
      product.featured_image
      | image_url: width: img_size, height: img_size, crop: 'center'
      | image_tag:
        loading: 'lazy',
        class: 'product-card__image',
        alt: product.featured_image.alt | default: product.title
    }}
  {% else %}
    <div class="product-card__image product-card__image--placeholder" aria-hidden="true"></div>
  {% endif %}

  <div class="product-card__info">
    <p class="product-card__title">{{ product.title | escape }}</p>
    {% if product.metafields.custom.artist_name != blank %}
      <p class="product-card__artist">{{ product.metafields.custom.artist_name }}</p>
    {% endif %}
    <p class="product-card__price">
      {%- if product.compare_at_price > product.price -%}
        <span class="product-card__price--sale">{{ product.price | money }}</span>
        <s class="product-card__price--compare">{{ product.compare_at_price | money }}</s>
      {%- else -%}
        {{ product.price | money }}
      {%- endif -%}
    </p>
  </div>
</a>

{% stylesheet %}
  .product-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-black);
  }

  .product-card__image {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    border: outset 2px transparent;
  }

  .product-card__image--placeholder {
    background: #ccc;
  }

  .product-card:hover .product-card__image,
  .product-card:focus-visible .product-card__image {
    opacity: 0.85;
  }

  .product-card:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 2px;
  }

  .product-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .product-card__title {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1.3;
  }

  .product-card__artist {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 400;
  }

  .product-card__price {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    margin-top: 0.125rem;
  }

  .product-card__price--sale {
    color: var(--color-red);
  }

  .product-card__price--compare {
    font-weight: 400;
    color: #888;
    margin-left: 0.375rem;
  }
{% endstylesheet %}
