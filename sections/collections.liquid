{% comment %}
  Artists page: lists all collections where custom.type == 'artist'.
  Each artist card shows their featured image, name, and links to their collection.
{% endcomment %}

<div class="artists-page">
  <div class="section-header-bar full-width">
    <span class="section-header-bar__title">ARTISTS</span>
  </div>

  <div class="artists-page__body full-width">
    <div class="artists-page__inner">
      <div class="artists-grid">
        {%- assign has_artists = false -%}
        {%- for c in collections -%}
          {%- if c.metafields.custom.type == 'artist' -%}
            {%- assign has_artists = true -%}
            <a href="{{ c.url }}" class="artist-card">
              <div class="artist-card__image-wrap">
                {%- if c.featured_image -%}
                  {{
                    c.featured_image
                    | image_url: width: 400, height: 400, crop: 'center'
                    | image_tag:
                      loading: 'lazy',
                      class: 'artist-card__image',
                      alt: c.title
                  }}
                {%- else -%}
                  <div class="artist-card__image artist-card__image--placeholder" aria-hidden="true"></div>
                {%- endif -%}
              </div>
              <p class="artist-card__name">{{ c.title }}</p>
            </a>
          {%- endif -%}
        {%- endfor -%}

        {%- unless has_artists -%}
          <p class="artists-grid__empty">No artists found.</p>
        {%- endunless -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .artists-page__body {
    background: var(--color-section-bg);
    padding: 2rem var(--page-margin);
  }

  .artists-page__inner {
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .artists-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(200px, 100%), 1fr));
    gap: 2rem;
  }

  .artists-grid__empty {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: #666;
  }

  .artist-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-decoration: none;
    color: var(--color-black);
  }

  .artist-card:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 4px;
  }

  .artist-card__image-wrap {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #ddd;
  }

  .artist-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.2s ease;
  }

  .artist-card:hover .artist-card__image {
    transform: scale(1.03);
  }

  .artist-card__image--placeholder {
    background: #aaa;
  }

  .artist-card__name {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
  }

  @media screen and (max-width: 768px) {
    .artists-page__body {
      padding: 1.5rem 1rem;
    }

    .artists-grid {
      grid-template-columns: repeat(auto-fill, minmax(min(140px, 100%), 1fr));
      gap: 1.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Artists",
  "settings": [],
  "presets": [
    {
      "name": "Artists"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
