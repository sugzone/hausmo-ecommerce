{% comment %}
  Home: Featured Releases section.
  Decorative area (logo + wordmark + tagline) occupies the first 2 grid columns
  of row 1. Products fill the remaining columns, then continue on subsequent rows.
{% endcomment %}

<div class="home-section home-section--releases">
  <div class="section-header-bar full-width">
    <span class="section-header-bar__title">{{ section.settings.header_text }}</span>
  </div>

  <div class="home-section__body full-width">
    <div class="home-section__inner">
      <div class="home-section__grid">
        <!-- Decorative: spans first 2 columns of the grid -->
        <div class="home-section__decorative" aria-hidden="true">
          <img
            src="{{ 'hausu-mountain-logo.png' | asset_url }}"
            alt=""
            class="home-section__logo"
            width="128"
            height="242"
            onerror="this.style.display='none'"
          >
          <div class="home-section__brand">
            <p class="home-section__tagline">{{ section.settings.tagline }}</p>
            <p class="home-section__wordmark">Hausu Mountain</p>
          </div>
        </div>

        <!-- Products fill remaining grid cells -->
        {% assign featured_collection = section.settings.collection %}
        {% if featured_collection != blank %}
          {% for product in featured_collection.products limit: section.settings.product_count %}
            {% render 'product-card', product: product %}
          {% endfor %}
        {% else %}
          <p class="home-section__no-collection">
            Select a collection in the theme editor to display products here.
          </p>
        {% endif %}
      </div>

      <div class="home-section__footer">
        <a href="{{ routes.collections_url }}/music" class="more-btn">more...</a>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .home-section {
    background: var(--color-section-bg);
  }

  .home-section__body {
    background: var(--color-section-bg);
    padding: 2rem var(--page-margin);
  }

  .home-section__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* 4-column grid; decorative spans cols 1-2 */
  .home-section__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .home-section__decorative {
    grid-column: 1 / 3;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 1rem;
  }

  .home-section__logo {
    width: 80px;
    height: auto;
    flex-shrink: 0;
    display: block;
  }

  .home-section__brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .home-section__tagline {
    font-family: var(--font-pixel-sans);
    font-weight: 700;
    font-size: 2.75rem;
    color: var(--color-purple);
    line-height: 1.1;
  }

  .home-section__wordmark {
    font-family: var(--font-pixel-sans);
    font-weight: 700;
    font-size: 2rem;
    color: var(--color-purple);
    white-space: nowrap;
  }

  .home-section__footer {
    display: flex;
    justify-content: flex-end;
  }

  .home-section__no-collection {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: #666;
    grid-column: 3 / -1;
  }

  @media screen and (max-width: 1024px) {
    .home-section__grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .home-section__decorative {
      grid-column: 1 / -1;
      flex-direction: row;
    }

    .home-section__tagline {
      font-size: 2rem;
    }
  }

  @media screen and (max-width: 768px) {
    .home-section__body {
      padding: 1.5rem 1rem;
    }

    .home-section__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .home-section__decorative {
      grid-column: 1 / -1;
    }

    .home-section__tagline {
      font-size: 1.5rem;
    }

    .home-section__wordmark {
      font-size: 1.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Releases",
  "settings": [
    {
      "type": "text",
      "id": "header_text",
      "label": "Section header text",
      "default": "Engage in Commerce!"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Decorative tagline",
      "default": "FRESH & HOT FROM THE BISCUIT FACTORY"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to feature"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Number of products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Featured Releases"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
