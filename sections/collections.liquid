{% comment %}
  Artists page: lists all collections where custom.type == 'artist'.
  Each artist card shows their featured image and name, links to their collection.
{% endcomment %}

<div class="artists-page full-width">
  <div class="panel-page">
    <div class="panel">
      <div class="panel__header">
        <h1 class="panel__header-title">ARTISTS</h1>
      </div>
      <div class="panel__body">
        <div class="artists-grid">
          {%- assign has_artists = false -%}
          {%- for c in collections -%}
            {%- if c.metafields.custom.type == 'artist' -%}
              {%- assign has_artists = true -%}
              <a href="{{ c.url }}" class="artist-card">
                <div class="artist-card__image-wrap">
                  {%- if c.featured_image -%}
                    {{
                      c.featured_image
                      | image_url: width: 400, height: 400, crop: 'center'
                      | image_tag:
                        loading: 'lazy',
                        class: 'artist-card__image',
                        alt: c.title
                    }}
                  {%- else -%}
                    <div class="artist-card__image artist-card__image--placeholder" aria-hidden="true"></div>
                  {%- endif -%}
                </div>
                <h2 class="artist-card__name">{{ c.title }}</h2>
              </a>
            {%- endif -%}
          {%- endfor -%}

          {%- unless has_artists -%}
            <p class="artists-grid__empty">No artists found.</p>
          {%- endunless -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .artists-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    column-gap: 1vw;
    row-gap: 1vh;
  }

  .artists-grid__empty {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: #666;
  }

  .artist-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-decoration: none;
    color: var(--color-black);
  }

  .artist-card:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 4px;
  }

  .artist-card__image-wrap {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #ddd;
  }

  .artist-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.2s ease;
  }

  .artist-card:hover .artist-card__image {
    transform: scale(1.03);
  }

  .artist-card__image--placeholder {
    background: #aaa;
  }

  .artist-card__name {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.5rem;
    text-transform: uppercase;
    text-decoration: underline;
  }

  @media screen and (max-width: 768px) {
    .artists-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 480px) {
    .artists-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Artists",
  "settings": [],
  "presets": [
    {
      "name": "Artists"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
