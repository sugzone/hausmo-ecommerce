{% comment %}
  Home: Featured Apparel section.
  Decorative text (Pixelify Sans) spans first 2 columns of row 1.
  6 products fill the remaining cells across 2 rows of 4 columns.
{% endcomment %}

<div class="home-section home-section--merch full-width">
  <div class="panel-page">
    <div class="panel">
      <div class="panel__header">
        <span class="panel__header-title">{{ section.settings.header_text }}</span>
      </div>
      <div class="panel__body">
        <div class="home-merch__grid">
          <!-- Decorative: spans first 2 columns of row 1 -->
          <div class="home-merch__decorative" aria-hidden="true">
            <p class="home-section__tagline">{{ section.settings.tagline }}</p>
            <p class="home-section__wordmark">Hausu Mountain</p>
          </div>

          <!-- Products fill remaining cells -->
          {%- assign featured_collection = section.settings.collection -%}
          {%- if featured_collection != blank -%}
            {%- for product in featured_collection.products limit: section.settings.product_count -%}
              {%- render 'product-card', product: product -%}
            {%- endfor -%}
          {%- else -%}
            <p class="home-section__no-collection">
              Select a collection in the theme editor to display products here.
            </p>
          {%- endif -%}
        </div>

        <div class="home-section__footer">
          <a href="{{ routes.collections_url }}/apparel" class="more-btn">more...</a>
        </div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  /* 4 columns, 2 fixed-height rows; decorative spans cols 1–2 */
  .home-merch__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, 325px);
    column-gap: 1vw;
    row-gap: 1vh;
  }

  .home-merch__decorative {
    grid-column: span 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
    overflow: hidden;
  }

  /* Merch context: artist name also bold */
  .home-section--merch .product-card__artist {
    font-weight: 700;
  }

  @media screen and (max-width: 1024px) {
    .home-merch__grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: auto;
    }

    .home-merch__decorative {
      grid-column: 1 / -1;
    }
  }

  @media screen and (max-width: 768px) {
    .home-merch__grid {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 2vw;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Merch",
  "settings": [
    {
      "type": "text",
      "id": "header_text",
      "label": "Section header text",
      "default": "CLOTHING & HOT ITEMS!"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Decorative tagline",
      "default": "Garb Yourself In HausMo"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to feature"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Number of products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "Featured Merch"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
