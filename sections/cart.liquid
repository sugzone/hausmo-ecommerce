{% comment %}
  Cart page (/cart) — fallback when cart drawer is not used or JS is disabled.
  Full cart view with item list, quantity updates, and checkout button.
{% endcomment %}

<div class="cart-page">
  <div class="section-header-bar full-width">
    <span class="section-header-bar__title">YOUR CART</span>
  </div>

  <div class="cart-page__body full-width">
    <div class="cart-page__inner">
      {%- if cart.item_count == 0 -%}
        <p class="cart-page__empty">Your cart is empty. <a href="{{ routes.collections_url }}/music" class="cart-page__empty-link">Keep shopping</a></p>
      {%- else -%}
        <form action="{{ routes.cart_url }}" method="post" class="cart-form" id="cart-page-form">
          <div class="cart-items" role="list" aria-label="Cart items">
            {%- for item in cart.items -%}
              <div class="cart-item" role="listitem">
                <a href="{{ item.url }}" class="cart-item__image-link" tabindex="-1" aria-hidden="true">
                  {%- if item.image -%}
                    {{
                      item.image
                      | image_url: width: 120, height: 120, crop: 'center'
                      | image_tag: loading: 'lazy', class: 'cart-item__image', alt: item.title | escape
                    }}
                  {%- else -%}
                    <div class="cart-item__image-placeholder"></div>
                  {%- endif -%}
                </a>

                <div class="cart-item__info">
                  <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                  {%- unless item.variant.title == 'Default Title' -%}
                    <p class="cart-item__variant">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  <p class="cart-item__price">{{ item.price | money }}</p>
                  <a href="{{ item.url_to_remove }}" class="cart-item__remove" aria-label="Remove {{ item.title | escape }} from cart">Remove</a>
                </div>

                <div class="cart-item__qty">
                  <label class="sr-only" for="qty-{{ item.key }}">Quantity for {{ item.title | escape }}</label>
                  <input
                    type="number"
                    id="qty-{{ item.key }}"
                    name="updates[]"
                    value="{{ item.quantity }}"
                    min="0"
                    class="cart-item__qty-input"
                    aria-label="Quantity"
                  >
                </div>

                <p class="cart-item__line-price">{{ item.line_price | money }}</p>
              </div>
            {%- endfor -%}
          </div>

          <div class="cart-page__footer">
            <div class="cart-page__totals">
              <p class="cart-page__subtotal-label">Subtotal</p>
              <p class="cart-page__subtotal">{{ cart.total_price | money }}</p>
            </div>

            <div class="cart-page__actions">
              <button type="submit" name="update" class="cart-page__update-btn">
                Update Cart
              </button>
              <button type="submit" name="checkout" class="cart-page__checkout-btn">
                Checkout
              </button>
            </div>
          </div>
        </form>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .cart-page__body {
    background: var(--color-section-bg);
    padding: 2rem var(--page-margin);
  }

  .cart-page__inner {
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .cart-page__empty {
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 2rem 0;
  }

  .cart-page__empty-link {
    color: var(--color-blue);
    font-weight: 700;
  }

  /* Cart items */
  .cart-items {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 2px solid var(--color-black);
  }

  .cart-item {
    display: grid;
    grid-template-columns: 80px 1fr auto auto;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid #ddd;
  }

  .cart-item__image-link {
    display: block;
    width: 80px;
    height: 80px;
    flex-shrink: 0;
  }

  .cart-item__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cart-item__image-placeholder {
    width: 80px;
    height: 80px;
    background: #ccc;
  }

  .cart-item__info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .cart-item__title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--color-black);
    text-decoration: none;
    text-transform: uppercase;
  }

  .cart-item__title:hover {
    text-decoration: underline;
  }

  .cart-item__variant {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: #666;
  }

  .cart-item__price {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: #555;
  }

  .cart-item__remove {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-red);
    text-decoration: none;
    margin-top: 0.25rem;
    display: inline-block;
  }

  .cart-item__remove:hover {
    text-decoration: underline;
  }

  .cart-item__qty-input {
    width: 56px;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    text-align: center;
    padding: 0.375rem 0.5rem;
    border: 2px solid var(--color-black);
    background: var(--color-white);
    -moz-appearance: textfield;
  }

  .cart-item__qty-input::-webkit-inner-spin-button,
  .cart-item__qty-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
  }

  .cart-item__qty-input:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 2px;
  }

  .cart-item__line-price {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.9375rem;
    text-align: right;
    white-space: nowrap;
  }

  /* Footer */
  .cart-page__footer {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem 0;
    flex-wrap: wrap;
  }

  .cart-page__totals {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  .cart-page__subtotal-label {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
  }

  .cart-page__subtotal {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.25rem;
  }

  .cart-page__actions {
    display: flex;
    gap: 0.75rem;
  }

  .cart-page__update-btn {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    padding: 0.75rem 1.25rem;
    background: none;
    border: 2px solid var(--color-black);
    color: var(--color-black);
    cursor: pointer;
    text-transform: uppercase;
  }

  .cart-page__update-btn:hover {
    background: var(--color-black);
    color: var(--color-white);
  }

  .cart-page__update-btn:focus-visible,
  .cart-page__checkout-btn:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 2px;
  }

  .cart-page__checkout-btn {
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    padding: 0.875rem 1.5rem;
    background: var(--color-red);
    color: var(--color-white);
    border: none;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cart-page__checkout-btn:hover {
    background: #cc0003;
  }

  @media screen and (max-width: 768px) {
    .cart-page__body {
      padding: 1.5rem 1rem;
    }

    .cart-item {
      grid-template-columns: 64px 1fr;
      grid-template-rows: auto auto;
    }

    .cart-item__image-link {
      width: 64px;
      height: 64px;
      grid-row: span 2;
    }

    .cart-item__qty {
      grid-column: 2;
    }

    .cart-item__line-price {
      grid-column: 2;
      text-align: left;
    }

    .cart-page__footer {
      flex-direction: column;
      align-items: flex-end;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Cart",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
