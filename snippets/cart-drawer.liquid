<dialog
  id="cart-drawer"
  class="cart-drawer"
  aria-label="Shopping cart"
  aria-modal="true"
>
  <div class="cart-drawer__inner">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__heading">Cart</h2>
      <button class="cart-drawer__close" aria-label="Close cart">&#x2715;</button>
    </div>

    <div class="cart-drawer__body" id="cart-drawer-body">
      <p class="cart-drawer__empty">Your cart is empty.</p>
    </div>

    <div class="cart-drawer__footer">
      <div class="cart-drawer__subtotal">
        <span>Subtotal</span>
        <span class="cart-drawer__footer-subtotal"></span>
      </div>
      <form action="{{ routes.cart_url }}/checkout" method="post">
        <button type="submit" class="cart-drawer__checkout">Checkout</button>
      </form>
      <button type="button" class="cart-drawer__continue" aria-label="Close cart and continue shopping">Continue Shopping</button>
    </div>
  </div>
</dialog>

{% stylesheet %}
  .cart-drawer {
    position: fixed;
    inset: 0 0 0 auto;
    width: min(370px, 100vw);
    height: 100%;
    max-height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background: var(--color-white);
    color: var(--color-black);
  }

  /* Must use [open] selector — setting display on the element itself
     overrides the browser's native dialog { display: none } default */
  .cart-drawer[open] {
    display: flex;
    flex-direction: column;
  }

  .cart-drawer::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }

  .cart-drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-black);
    flex-shrink: 0;
  }

  .cart-drawer__heading {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-black);
  }

  .cart-drawer__close {
    background: none;
    border: none;
    color: var(--color-black);
    font-size: 1.25rem;
    cursor: pointer;
    padding: 0.25rem;
    line-height: 1;
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart-drawer__close:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 2px;
  }

  .cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 1.25rem;
  }

  .cart-drawer__empty {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    text-align: center;
    padding: 2rem 0;
  }

  .cart-drawer__item {
    display: flex;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-section-bg);
  }

  .cart-drawer__item-image img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .cart-drawer__item-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .cart-drawer__item-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    color: var(--color-black);
  }

  .cart-drawer__item-variant {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #555;
  }

  .cart-drawer__item-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .cart-drawer__qty {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--color-black);
  }

  .cart-drawer__qty-btn {
    background: none;
    border: none;
    cursor: pointer;
    width: 28px;
    height: 28px;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
  }

  .cart-drawer__qty-val {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    min-width: 1.5rem;
    text-align: center;
  }

  .cart-drawer__item-price {
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  .cart-drawer__remove {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-decoration: underline;
    padding: 0;
    color: var(--color-black);
    min-height: 44px;
  }

  .cart-drawer__footer {
    padding: 1rem 1.25rem;
    border-top: 2px solid var(--color-black);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1rem;
  }

  .cart-drawer__checkout {
    width: 100%;
    padding: 0.75rem;
    background: var(--color-black);
    border: none;
    color: var(--color-white);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    min-height: 44px;
  }

  .cart-drawer__checkout:hover {
    opacity: 0.85;
  }

  .cart-drawer__checkout:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 2px;
  }

  .cart-drawer__continue {
    background: none;
    border: none;
    padding: 0;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-black);
    text-decoration: underline;
    cursor: pointer;
    text-align: center;
    min-height: 44px;
    width: 100%;
  }

  .cart-drawer__continue:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 2px;
  }
{% endstylesheet %}
