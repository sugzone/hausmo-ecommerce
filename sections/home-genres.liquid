{% comment %}
  Displays genre collections as image buttons.
  Loops through all collections and filters by metafield custom.type == 'genre'.
  Each button uses the collection's featured_image as background and title as label.
  Font size starts at 44px and scales down via JS (theme.js: scaleGenreButtons).
{% endcomment %}

<div class="home-section home-section--genres">
  <div class="section-header-bar full-width">
    <span class="section-header-bar__title">{{ section.settings.header_text }}</span>
  </div>

  <div class="home-section__body full-width">
    <div class="home-section__inner">
      <div class="home-section__decorative" aria-hidden="true">
        <p class="home-section__tagline">{{ section.settings.tagline }}</p>
        <p class="home-section__wordmark">Hausu Mountain</p>
      </div>

      <div class="genre-grid">
        {% for c in collections %}
          {% if c.metafields.custom.type == 'genre' %}
            <a
              href="{{ c.url }}"
              class="genre-btn"
              aria-label="{{ c.title }}"
            >
              {% if c.featured_image %}
                {{
                  c.featured_image
                  | image_url: width: 400, height: 400, crop: 'center'
                  | image_tag:
                    loading: 'lazy',
                    class: 'genre-btn__bg',
                    alt: '',
                    aria-hidden: 'true'
                }}
              {% else %}
                <div class="genre-btn__bg genre-btn__bg--placeholder" aria-hidden="true"></div>
              {% endif %}
              <span class="genre-btn__text" aria-hidden="true">{{ c.title }}</span>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .genre-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .genre-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 200px;
    height: 90px;
    overflow: hidden;
    text-decoration: none;
    border-style: outset;
    border-width: 2px;
    border-color: #888;
    flex-shrink: 0;
  }

  .genre-btn:focus-visible {
    outline: 3px solid var(--color-blue);
    outline-offset: 2px;
  }

  .genre-btn__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .genre-btn__bg--placeholder {
    background: #555;
  }

  /* Dark overlay so white text is readable over any image */
  .genre-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
  }

  .genre-btn__text {
    position: relative;
    z-index: 1;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 44px; /* JS scales this down as needed */
    color: var(--color-white);
    /* Black outline via text-shadow — accessible alternative to -webkit-text-stroke */
    text-shadow:
      -2px -2px 0 #000,
       2px -2px 0 #000,
      -2px  2px 0 #000,
       2px  2px 0 #000;
    white-space: normal;
    word-break: keep-all;
    overflow-wrap: normal;
    text-align: center;
    line-height: 1.1;
    padding: 0 0.5rem;
  }

  @media screen and (max-width: 768px) {
    .genre-btn {
      width: calc(50% - 0.375rem);
      height: 80px;
    }
  }

  @media screen and (max-width: 480px) {
    .genre-btn {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Genres",
  "settings": [
    {
      "type": "text",
      "id": "header_text",
      "label": "Section header text",
      "default": "PERUSE THE HAUSMO CATALOG"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Decorative tagline",
      "default": "Select A Zone From Our Lavish Menu"
    }
  ],
  "presets": [
    {
      "name": "Genres"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
