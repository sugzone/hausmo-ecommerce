{% liquid
  assign current_path = request.path
%}

<header class="site-header full-width" role="banner">
  <!-- Top bar: logo + site name (blue) -->
  <div class="header__top">
    {%- if section.settings.logo != blank -%}
      {{
        section.settings.logo
        | image_url: width: 78, height: 78
        | image_tag: alt: shop.name, class: 'header__logo-img', loading: 'eager'
      }}
    {%- else -%}
      <img
        src="{{ 'hausmo-logo-standard.png' | asset_url }}"
        alt="{{ shop.name }}"
        class="header__logo-img"
        width="78"
        height="78"
      >
    {%- endif -%}
    <h1 class="header__site-name">Hausu Mountain E-Shoppe</h1>
  </div>

  <!-- Bottom bar: nav + search/cart (gray) -->
  <div class="header__bottom">
    <nav class="header__nav" aria-label="Main navigation">
      <div class="header__nav-left">
        <a
          href="{{ routes.root_url }}"
          class="header__nav-item{% if current_path == '/' %} is-active{% endif %}"
          {% if current_path == '/' %}aria-current="page"{% endif %}
        >
          <img src="{{ 'home.svg' | asset_url }}" alt="" aria-hidden="true" class="header__nav-icon" width="48" height="48">
          <span class="header__nav-label">Home</span>
        </a>

        <a
          href="{{ routes.collections_url }}/music"
          class="header__nav-item{% if current_path contains '/collections/music' %} is-active{% endif %}"
          {% if current_path contains '/collections/music' %}aria-current="page"{% endif %}
        >
          <img src="{{ 'music.svg' | asset_url }}" alt="" aria-hidden="true" class="header__nav-icon" width="48" height="48">
          <span class="header__nav-label">Music</span>
        </a>

        <a
          href="{{ routes.collections_url }}/merch"
          class="header__nav-item{% if current_path contains '/collections/merch' %} is-active{% endif %}"
          {% if current_path contains '/collections/merch' %}aria-current="page"{% endif %}
        >
          <img src="{{ 'apparel.svg' | asset_url }}" alt="" aria-hidden="true" class="header__nav-icon" width="48" height="48">
          <span class="header__nav-label">Merch</span>
        </a>

        <a
          href="/pages/artists"
          class="header__nav-item{% if current_path contains '/pages/artists' %} is-active{% endif %}"
          {% if current_path contains '/pages/artists' %}aria-current="page"{% endif %}
        >
          <img src="{{ 'artists.svg' | asset_url }}" alt="" aria-hidden="true" class="header__nav-icon" width="48" height="48">
          <span class="header__nav-label">Artists</span>
        </a>
      </div>

      <div class="header__nav-right">
        <button
          class="header__nav-item header__search-btn"
          aria-expanded="false"
          aria-controls="search-dropdown"
          aria-label="Search"
        >
          <img src="{{ 'search.svg' | asset_url }}" alt="" aria-hidden="true" class="header__nav-icon" width="48" height="48">
          <span class="header__nav-label">Search</span>
        </button>

        <button
          class="header__nav-item header__cart-btn"
          aria-expanded="false"
          aria-controls="cart-drawer"
          aria-label="Cart{% if cart.item_count > 0 %}, {{ cart.item_count }} {% if cart.item_count == 1 %}item{% else %}items{% endif %}{% endif %}"
        >
          <span class="header__cart-icon-wrap">
            <img src="{{ 'cart.svg' | asset_url }}" alt="" aria-hidden="true" class="header__nav-icon" width="48" height="48">
            {% if cart.item_count > 0 %}
              <span class="cart-count" aria-hidden="true">{{ cart.item_count }}</span>
            {% endif %}
          </span>
          <span class="header__nav-label">Cart</span>
        </button>
      </div>
    </nav>
  </div>
</header>

{% stylesheet %}
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  /* Top bar: blue, logo + site name */
  .header__top {
    background: var(--color-blue);
    height: fit-content;
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .header__logo-img {
    height: 58px;
    width: auto;
    flex-shrink: 0;
  }

  .header__site-name {
    font-family: var(--font-pixel);
    font-size: var(--theme-font-size-large);
    color: var(--color-white);
    white-space: nowrap;
  }

  /* Bottom bar: gray, nav only */
  .header__bottom {
    background: var(--color-nav-bg);
    height: var(--header-bottom-height);
    display: flex;
    align-items: center;
    padding: 0 1.5rem;
  }

  /* Nav: left cluster | right cluster, space between */
  .header__nav {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header__nav-left,
  .header__nav-right {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* Nav items */
  .header__nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
    text-decoration: none;
    color: var(--color-black);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    min-width: 44px;
    min-height: 44px;
    justify-content: center;
  }


  .header__nav-item.is-active .header__nav-label {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .header__nav-icon {
    width: 3rem;
    height: 3rem;
    flex-shrink: 0;
  }

  .header__nav-label {
    font-family: var(--font-sans);
    font-size: var(--theme-font-size-large);
    font-weight: 400;
    white-space: nowrap;
  }

  /* Cart badge */
  .header__cart-icon-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart-count {
    position: absolute;
    top: -6px;
    right: -10px;
    background: var(--color-red);
    color: var(--color-white);
    font-family: var(--font-mono);
    font-size: var(--theme-font-size-2x-small);
    font-weight: 700;
    line-height: 1;
    min-width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
  }

  /* Mobile */
  @media screen and (max-width: 768px) {
    .header__top {
      padding: 0 1rem;
      gap: 0.75rem;
    }

    .header__logo-img {
      height: 48px;
    }

    .header__site-name {
      font-size: var(--theme-font-size-small);
    }

    .header__bottom {
      padding: 0 1rem;
    }

    .header__nav-left,
    .header__nav-right {
      gap: 0.75rem;
    }

    .header__nav-label {
      font-size: var(--theme-font-size-small);
    }

    .header__nav-icon {
      width: 1.75rem;
      height: 1.75rem;
    }
  }

  @media screen and (max-width: 480px) {
    .header__nav-label {
      display: none;
    }

    .header__nav-left,
    .header__nav-right {
      gap: 0.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    }
  ]
}
{% endschema %}
