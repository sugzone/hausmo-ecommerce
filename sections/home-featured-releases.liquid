{% comment %}
  Home: Featured Releases section.
  Decorative area (logo + wordmark + tagline) spans first 2 columns of row 1.
  6 products fill the remaining cells across 2 rows of 4 columns.
{% endcomment %}

<div class="home-section home-section--releases full-width">
  <div class="panel-page">
    <div class="panel">
      <div class="panel__header">
        <h2 class="panel__header-title">{{ section.settings.header_text }}</h2>
      </div>
      <div class="panel__body">
        <div class="home-releases__grid">
          <!-- Decorative: spans first 2 columns of row 1 -->
          <div class="home-releases__decorative" aria-hidden="true">
            <img
              src="{{ 'hausu-mountain-logo.png' | asset_url }}"
              alt=""
              class="home-section__logo"
              width="128"
              height="242"
              onerror="this.style.display='none'"
            >
            <div class="home-section__brand">
              <p class="home-section__tagline">{{ section.settings.tagline }}</p>
              <p class="home-section__wordmark">Hausu Mountain</p>
            </div>
          </div>

          <!-- Products fill remaining cells -->
          {%- assign featured_collection = section.settings.collection -%}
          {%- if featured_collection != blank -%}
            {%- for product in featured_collection.products limit: section.settings.product_count -%}
              {%- render 'product-card', product: product -%}
            {%- endfor -%}
          {%- else -%}
            <p class="home-section__no-collection">
              Select a collection in the theme editor to display products here.
            </p>
          {%- endif -%}
        </div>

        <div class="home-section__footer">
          <a href="{{ routes.collections_url }}/music" class="more-btn">more...</a>
        </div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  /* 4 columns, 2 fixed-height rows; decorative spans cols 1–2 */
  .home-releases__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, 325px);
    column-gap: 1vw;
    row-gap: 1vh;
  }

  .home-releases__decorative {
    grid-column: span 2;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 1rem;
    overflow: hidden;
  }

  .home-section__logo {
    width: 80px;
    height: auto;
    flex-shrink: 0;
    display: block;
  }

  .home-section__brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .home-section__tagline {
    font-family: var(--font-pixel-sans);
    font-weight: 700;
    font-size: 2.75rem;
    color: var(--color-purple);
    line-height: 1.1;
  }

  .home-section__wordmark {
    font-family: var(--font-pixel-sans);
    font-weight: 700;
    font-size: 2rem;
    color: var(--color-purple);
    white-space: nowrap;
  }

  .home-section__footer {
    display: flex;
    justify-content: flex-end;
    margin-top: 1.5rem;
  }

  .home-section__no-collection {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: #666;
    grid-column: 3 / -1;
  }

  @media screen and (max-width: 1024px) {
    .home-releases__grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: auto;
    }

    .home-releases__decorative {
      grid-column: 1 / -1;
    }

    .home-section__tagline {
      font-size: 2rem;
    }
  }

  @media screen and (max-width: 768px) {
    .home-releases__grid {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 2vw;
    }

    .home-section__tagline {
      font-size: 1.5rem;
    }

    .home-section__wordmark {
      font-size: 1.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Releases",
  "settings": [
    {
      "type": "text",
      "id": "header_text",
      "label": "Section header text",
      "default": "Engage in Commerce!"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Decorative tagline",
      "default": "FRESH & HOT FROM THE BISCUIT FACTORY"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to feature"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Number of products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "Featured Releases"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
