<footer class="site-footer full-width" role="contentinfo">
  <div class="footer__inner">
    <div class="footer__brand">
      <a href="https://hausumountain.com" class="footer__wordmark" target="_blank" rel="noopener">Hausu Mountain</a>
      <p class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.<br>
        <a href="mailto:doug@hausumountain.com" class="footer__contact">Contact</a>
      </p>
      {%- if section.settings.show_payment_icons -%}
        <div class="footer__payment" aria-label="Accepted payment methods">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.menu.links.size > 0 -%}
      <nav class="footer__nav" aria-label="Footer navigation">
        {%- for link in section.settings.menu.links -%}
          <a
            href="{{ link.url }}"
            class="footer__nav-link"
            {% if link.url == request.path %}aria-current="page"{% endif %}
          >
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>
    {%- endif -%}
  </div>

  <div class="footer__bottom full-width">
    {{ powered_by_link }}
  </div>
</footer>

{% stylesheet %}
  .site-footer {
    background: var(--color-black);
    color: var(--color-white);
    padding: 2.5rem var(--page-margin) 0;
  }

  .footer__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    flex-wrap: wrap;
    padding-bottom: 2rem;
  }

  .footer__wordmark {
    font-family: var(--font-pixel-sans);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-white);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .footer__wordmark:hover {
    text-decoration: underline;
  }

  .footer__wordmark:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 2px;
  }

  .footer__contact {
    color: #aaa;
    text-decoration: underline;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .footer__contact:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 2px;
  }

  .footer__copyright {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #aaa;
  }

  .footer__copyright a {
    color: #aaa;
    text-decoration: none;
  }

  .footer__payment {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .footer__payment svg {
    height: 24px;
    width: auto;
    opacity: 0.7;
  }

  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer__nav-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-white);
    text-decoration: none;
    text-transform: uppercase;
  }

  .footer__nav-link:hover,
  .footer__nav-link[aria-current="page"] {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer__nav-link:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 2px;
  }

  .footer__bottom {
    border-top: 1px solid #333;
    padding: 0.75rem var(--page-margin);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: #666;
    text-align: center;
  }

  .footer__bottom a {
    color: #666;
    text-decoration: none;
  }

  @media screen and (max-width: 768px) {
    .site-footer {
      padding: 2rem 1rem 0;
    }

    .footer__inner {
      flex-direction: column;
      gap: 1.5rem;
    }

    .footer__bottom {
      padding: 0.75rem 1rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer menu"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ]
}
{% endschema %}
