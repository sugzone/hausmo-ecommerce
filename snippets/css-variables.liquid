{% style %}
  :root {
    /* Brand colours */
    --color-blue: #0060DD;
    --color-purple: #6C00F9;
    --color-red: #FF0004;
    --color-section-bg: #F6F6F6;
    --color-nav-bg: #D9D9D9;
    --color-black: #000000;
    --color-white: #FFFFFF;

    /* Mapped to skeleton conventions so existing CSS keeps working */
    --color-background: #FFFFFF;
    --color-foreground: #000000;

    /* Brand typefaces */
    --font-pixel: 'Press Start 2P', cursive;
    --font-pixel-sans: 'Pixelify Sans', cursive;
    --font-mono: 'IBM Plex Mono', monospace;
    --font-sans: 'Quantico', sans-serif;

    /* Layout */
    --page-width: {{ settings.max_page_width }};
    --page-margin: {{ settings.min_page_margin }}px;

    /* Header heights — top = blue logo/title bar, bottom = gray nav bar */
    --header-top-height: 90px;
    --header-bottom-height: 80px;
    --header-total-height: calc(var(--header-top-height) + var(--header-bottom-height));

    /* Font size scale */
    --theme-font-size-2x-small: 0.625rem;
    --theme-font-size-x-small: 0.75rem;
    --theme-font-size-small: 0.875rem;
    --theme-font-size-medium: 1rem;
    --theme-font-size-large: 1.5rem;
    --theme-font-size-x-large: 2rem;
    --theme-font-size-2x-large: 3rem;

    /* Misc */
    --style-border-radius-inputs: 0px;
    --icon-stroke-width: 1.5;
  }

  @media screen and (max-width: 768px) {
    :root {
      --header-top-height: 60px;
      --header-bottom-height: 60px;
    }
  }
{% endstyle %}
