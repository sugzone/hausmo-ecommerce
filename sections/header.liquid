{% liquid
  assign current_path = request.path
%}

<header class="site-header" role="banner">
  <!-- Top bar: scrolling marquee -->
  <div class="header__top" aria-hidden="true">
    <div class="header__marquee" role="presentation">
      <span class="header__marquee-track">
        {%- for i in (1..10) -%}
          Hausu Mountain E-Shoppe &nbsp;&nbsp;&nbsp;&nbsp;
        {%- endfor -%}
      </span>
    </div>
  </div>

  <!-- Bottom bar: logo (center) + navigation -->
  <div class="header__bottom">
    <nav class="header__nav" aria-label="Main navigation">
      <div class="header__nav-left">
        <a
          href="{{ routes.root_url }}"
          class="header__nav-item{% if current_path == '/' %} is-active{% endif %}"
          {% if current_path == '/' %}aria-current="page"{% endif %}
        >
          <img src="{{ 'home.svg' | asset_url }}" alt="" aria-hidden="true" class="header__nav-icon" width="48" height="48">
          <span class="header__nav-label">Home</span>
        </a>

        <a
          href="{{ routes.collections_url }}/music"
          class="header__nav-item{% if current_path contains '/collections/music' %} is-active{% endif %}"
          {% if current_path contains '/collections/music' %}aria-current="page"{% endif %}
        >
          <img src="{{ 'music.svg' | asset_url }}" alt="" aria-hidden="true" class="header__nav-icon" width="48" height="48">
          <span class="header__nav-label">Music</span>
        </a>

        <a
          href="{{ routes.collections_url }}/genres"
          class="header__nav-item{% if current_path contains '/collections/genres' %} is-active{% endif %}"
          {% if current_path contains '/collections/genres' %}aria-current="page"{% endif %}
        >
          <img src="{{ 'genres.svg' | asset_url }}" alt="" aria-hidden="true" class="header__nav-icon" width="48" height="48">
          <span class="header__nav-label">Genres</span>
        </a>

        <a
          href="{{ routes.collections_url }}/apparel"
          class="header__nav-item{% if current_path contains '/collections/apparel' %} is-active{% endif %}"
          {% if current_path contains '/collections/apparel' %}aria-current="page"{% endif %}
        >
          <img src="{{ 'apparel.svg' | asset_url }}" alt="" aria-hidden="true" class="header__nav-icon" width="48" height="48">
          <span class="header__nav-label">Apparel</span>
        </a>

        <a
          href="{{ routes.collections_url }}/artists"
          class="header__nav-item{% if current_path contains '/collections/artists' %} is-active{% endif %}"
          {% if current_path contains '/collections/artists' %}aria-current="page"{% endif %}
        >
          <img src="{{ 'artists.svg' | asset_url }}" alt="" aria-hidden="true" class="header__nav-icon" width="48" height="48">
          <span class="header__nav-label">Artists</span>
        </a>
      </div>

      <!-- Center logo -->
      <a href="{{ routes.root_url }}" class="header__logo" aria-label="{{ shop.name }} home">
        {%- if section.settings.logo != blank -%}
          {{
            section.settings.logo
            | image_url: width: 62, height: 116
            | image_tag: alt: shop.name, class: 'header__logo-img', loading: 'eager'
          }}
        {%- else -%}
          <img
            src="{{ 'hausu-mountain-logo.png' | asset_url }}"
            alt="{{ shop.name }}"
            class="header__logo-img"
            width="42"
            height="78"
            onerror="this.style.display='none'"
          >
        {%- endif -%}
      </a>

      <div class="header__nav-right">
        <button
          class="header__nav-item header__search-btn"
          aria-expanded="false"
          aria-controls="search-dropdown"
          aria-label="Search"
        >
          <img src="{{ 'search.svg' | asset_url }}" alt="" aria-hidden="true" class="header__nav-icon" width="48" height="48">
          <span class="header__nav-label">Search</span>
        </button>

        <button
          class="header__nav-item header__cart-btn"
          aria-expanded="false"
          aria-controls="cart-drawer"
          aria-label="Cart{% if cart.item_count > 0 %}, {{ cart.item_count }} {% if cart.item_count == 1 %}item{% else %}items{% endif %}{% endif %}"
        >
          <span class="header__cart-icon-wrap">
            <img src="{{ 'cart.svg' | asset_url }}" alt="" aria-hidden="true" class="header__nav-icon" width="48" height="48">
            {% if cart.item_count > 0 %}
              <span class="cart-count" aria-hidden="true">{{ cart.item_count }}</span>
            {% endif %}
          </span>
          <span class="header__nav-label">Cart</span>
        </button>
      </div>
    </nav>
  </div>
</header>

{% stylesheet %}
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
  }

  /* Top bar: blue marquee */
  .header__top {
    background: var(--color-blue);
    height: var(--header-top-height);
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .header__marquee {
    width: 100%;
    overflow: hidden;
  }

  .header__marquee-track {
    display: inline-block;
    white-space: nowrap;
    font-family: var(--font-pixel);
    font-size: 1.5rem;
    color: var(--color-white);
    animation: marquee 30s linear infinite;
    padding-left: 100%;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .header__marquee-track {
      animation: none;
      padding-left: 1.5rem;
    }
  }

  /* Bottom bar: gray nav */
  .header__bottom {
    background: var(--color-nav-bg);
    height: var(--header-bottom-height);
    display: flex;
    align-items: center;
    padding: 0 1.5rem;
  }

  /* Nav layout: left group | center logo | right group */
  .header__nav {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header__nav-left,
  .header__nav-right {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* Center logo */
  .header__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .header__logo-img {
    height: 78px;
    width: auto;
    display: block;
  }

  /* Nav items */
  .header__nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
    text-decoration: none;
    color: var(--color-black);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    min-width: 44px;
    min-height: 44px;
    justify-content: center;
  }

  .header__nav-item:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 2px;
  }

  .header__nav-item.is-active .header__nav-label {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .header__nav-icon {
    width: 3rem;
    height: 3rem;
    flex-shrink: 0;
  }

  .header__nav-label {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 400;
    white-space: nowrap;
  }

  /* Cart badge */
  .header__cart-icon-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart-count {
    position: absolute;
    top: -6px;
    right: -10px;
    background: var(--color-red);
    color: var(--color-white);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 700;
    line-height: 1;
    min-width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
  }

  /* Mobile */
  @media screen and (max-width: 768px) {
    .header__bottom {
      padding: 0 1rem;
    }

    .header__nav-left,
    .header__nav-right {
      gap: 0.75rem;
    }

    .header__nav-label {
      font-size: 0.875rem;
    }

    .header__nav-icon {
      width: 1.75rem;
      height: 1.75rem;
    }

    .header__logo-img {
      height: 48px;
    }

    .header__marquee-track {
      font-size: 0.875rem;
    }
  }

  @media screen and (max-width: 480px) {
    .header__nav-label {
      display: none;
    }

    .header__nav-left {
      gap: 0.5rem;
    }

    .header__nav-right {
      gap: 0.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    }
  ]
}
{% endschema %}
